# Vercel 배포 시 필요한 환경변수 목록 (Vercel 프로젝트 Settings > Environment Variables)

# Postgres 연결 문자열 (Neon/Supabase). 예: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# `npx auth secret` 으로 생성
AUTH_SECRET=

# Google Cloud Console > OAuth 2.0 클라이언트
# 승인된 리디렉션 URI: https://<도메인>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 네이버 개발자센터 > 애플리케이션 > 검색 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 배포 환경에서는 반드시 false (또는 아예 설정하지 않기)
ALLOW_DEV_LOGIN=false

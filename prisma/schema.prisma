// BookKing 데이터 모델 — Neon PostgreSQL
// (enum 대신 String 상수 사용 — src/lib/constants.ts 참고)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js 표준 모델 ─────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String? // 서비스 표시 이름 (가입 시 필수 등록)
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  memberships GroupMember[]
  records     ReadingRecord[]
  ownedGroups Group[]         @relation("GroupOwner")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── BookKing 도메인 모델 ──────────────────────────

model Group {
  id              String   @id @default(cuid())
  name            String
  ownerId         String
  inviteCode      String   @unique
  inviteExpiresAt DateTime // 발급 + 7일
  createdAt       DateTime @default(now())

  owner   User            @relation("GroupOwner", fields: [ownerId], references: [id])
  members GroupMember[]
  records ReadingRecord[]
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  role     String   @default("MEMBER") // OWNER | ADMIN | MEMBER
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId, role])
}

// 네이버 API 결과를 공유 엔티티로 저장 — ISBN으로 "같은 책" 판별
model Book {
  id           String   @id @default(cuid())
  isbn         String?  @unique
  title        String
  author       String
  publisher    String?
  thumbnailUrl String?
  link         String?
  price        Int?
  createdAt    DateTime @default(now())

  records ReadingRecord[]
}

model ReadingRecord {
  id             String    @id @default(cuid())
  userId         String
  groupId        String
  bookId         String
  status         String    @default("WISH") // WISH | READING | DONE
  startDate      DateTime?
  endDate        DateTime?
  rating         Int? // 0~10 (별 반 개 = 1, 예: 별 4.5개 = 9)
  recommendMbti  String? // "INFP,ENFP" 또는 "ALL"
  memorableQuote String?
  review         String?
  deletedAt      DateTime? // soft delete
  deletedBy      String? // 삭제한 사용자 id
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  book  Book  @relation(fields: [bookId], references: [id])

  @@index([groupId, status, deletedAt])
  @@index([userId, groupId])
  @@index([status, deletedAt]) // 통합 랭킹(그룹 필터 없음) 집계용
}

// BookKing 데이터 모델 — Neon PostgreSQL
// (enum 대신 String 상수 사용 — src/lib/constants.ts 참고)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js 표준 모델 ─────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String? // 서비스 표시 이름 (가입 시 필수 등록)
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  isSiteAdmin   Boolean   @default(false) // 최고 운영자 (쿠폰 발급·요청 처리)
  suspendedAt   DateTime? // 계정 정지 (사이트 관리자 제재)
  suspendedReason String?
  createdAt     DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  memberships       GroupMember[]
  records           ReadingRecord[]
  ownedGroups       Group[]            @relation("GroupOwner")
  createdGroups     Group[]            @relation("GroupCreator")
  slotGrants        SlotGrant[]
  couponRedemptions CouponRedemption[]
  slotRequests      SlotRequest[]
  joinRequests      GroupJoinRequest[]
  shareCards        ShareCard[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── BookKing 도메인 모델 ──────────────────────────

model Group {
  id              String   @id @default(cuid())
  name            String
  ownerId         String
  createdById     String? // 그룹 생성자 (불변 — 이용권 차감 기준, 위임과 무관)
  inviteCode      String   @unique
  inviteExpiresAt DateTime // 발급 + 7일
  searchable      Boolean  @default(false) // 외부 검색 허용 (검색 노출)
  readOnly        Boolean  @default(false) // 보기 전용 (그룹장·운영자만 기록 등록·수정)
  joinApproval    Boolean  @default(false) // 가입 승인제 (그룹장·운영자 승인 필요)
  isPersonal      Boolean  @default(false) // 개인 책장 (가입 시 자동 생성, 1인 전용, 이용권 미차감)
  createdAt       DateTime @default(now())

  owner        User               @relation("GroupOwner", fields: [ownerId], references: [id])
  createdBy    User?              @relation("GroupCreator", fields: [createdById], references: [id])
  members      GroupMember[]
  records      ReadingRecord[]
  joinRequests GroupJoinRequest[]
  sharedCards  ShareCardGroup[]

  @@index([createdById])
}

// 독서 결산 카드 — 유저×연도 1개. 공개(publicSlug) / 그룹 공유(ShareCardGroup)를 독립적으로 설정.
// 통계는 조회 시 실시간 계산(스냅샷 아님) — src/lib/wrapped.ts
model ShareCard {
  id         String   @id @default(cuid())
  userId     String
  year       Int
  publicSlug String?  @unique // 설정되면 /w/{slug} 공개 링크 활성
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups ShareCardGroup[]

  @@unique([userId, year])
}

model ShareCardGroup {
  id        String   @id @default(cuid())
  cardId    String
  groupId   String
  createdAt DateTime @default(now())

  card  ShareCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  group Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([cardId, groupId])
  @@index([groupId])
}

// 사이트 전역 설정 (제휴 ID 등) — 사이트 관리자가 UI에서 수정
model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// 가입 신청 — joinApproval 그룹은 그룹장·운영자 승인 후 가입됨
model GroupJoinRequest {
  id         String    @id @default(cuid())
  groupId    String
  userId     String
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  resolvedBy String? // 처리한 관리자 id

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, status])
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  role     String   @default("MEMBER") // OWNER | ADMIN | MEMBER
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId, role])
}

// 네이버 API 결과를 공유 엔티티로 저장 — ISBN으로 "같은 책" 판별
model Book {
  id           String   @id @default(cuid())
  isbn         String?  @unique
  title        String
  author       String
  publisher    String?
  thumbnailUrl String?
  link         String?
  price        Int?
  addonUrl     String? // 예스24 애드온 링크(link.yes24.com/a/…) — 최고 운영자가 수동 등록, eBook/크레마 버튼에 사용
  createdAt    DateTime @default(now())

  records ReadingRecord[]
}

model ReadingRecord {
  id             String    @id @default(cuid())
  userId         String
  groupId        String
  bookId         String
  status         String    @default("WISH") // WISH | READING | DONE
  startDate      DateTime?
  endDate        DateTime?
  rating         Int? // 0~10 (별 반 개 = 1, 예: 별 4.5개 = 9)
  recommendMbti  String? // "INFP,ENFP" 또는 "ALL"
  memorableQuote String?
  review         String?
  deletedAt      DateTime? // soft delete
  deletedBy      String? // 삭제한 사용자 id
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  book  Book  @relation(fields: [bookId], references: [id])

  @@index([groupId, status, deletedAt])
  @@index([userId, groupId])
  @@index([status, deletedAt]) // 통합 랭킹(그룹 필터 없음) 집계용
}

// ── 그룹 생성 이용권(슬롯) 시스템 ──────────────────
// 모든 유저는 기본 1개 + SlotGrant 수만큼 그룹 생성 가능.
// 사용량은 "생성한 그룹 수"(Group.createdById) 기준 — 위임해도 반환되지 않음.

// 지급된 이용권 (1행 = 1슬롯)
model SlotGrant {
  id        String   @id @default(cuid())
  userId    String
  source    String // COUPON | ADMIN | BACKFILL (| 추후 PURCHASE)
  couponId  String?
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Coupon {
  id         String    @id @default(cuid())
  code       String    @unique
  slotAmount Int       @default(1) // 1회 사용 시 지급되는 슬롯 수
  maxUses    Int       @default(1) // 총 사용 가능 횟수
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  note       String? // 관리자 메모 (발급 대상 등)
  createdAt  DateTime  @default(now())

  redemptions  CouponRedemption[]
  slotRequests SlotRequest[]
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId]) // 1인 1회
}

// 이용권 요청 — 사용자가 신청하면 사이트 관리자가 쿠폰을 발급해 승인
model SlotRequest {
  id             String    @id @default(cuid())
  userId         String
  requestedSlots Int       @default(1)
  message        String?
  status         String    @default("PENDING") // PENDING | APPROVED | REJECTED
  adminNote      String?
  couponId       String? // 승인 시 발급된 쿠폰
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon? @relation(fields: [couponId], references: [id])

  @@index([status, createdAt])
  @@index([userId])
}
